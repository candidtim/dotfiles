#!/bin/bash

if [ -z "$1" ]; then
  current=$(grep -o 'background=[a-zA-Z]*' ~/.config/nvim/init.vim | cut -d= -f2)
  theme=${current:-dark}
  [[ "$theme" == "dark" ]] && theme="light" || theme="dark"
else
  theme=$1
fi

echo "Switching to $theme theme."

if [[ "$(uname -s)" == "Darwin" ]]; then
  GHOSTTY_CONFIG=~/Library/Application\ Support/com.mitchellh.ghostty/config
  sedi() { sed -i '' "$@"; }
else
  GHOSTTY_CONFIG=~/.config/ghostty/config
  sedi() { sed -i "$@"; }
fi

# Vim:
sedi "s/background=[a-zA-Z]*/background=$theme/" ~/.config/nvim/init.vim
sedi "s/solarized_[a-zA-Z]*/solarized_$theme/" ~/.config/nvim/lua/init.lua

# tmux:
sedi "s/@colors-solarized '[a-zA-Z]*'/@colors-solarized '$theme'/" ~/.tmux.conf
tmux source-file ~/.tmux.conf

# Ghostty:
themeCap="$(tr '[:lower:]' '[:upper:]' <<< ${theme:0:1})${theme:1}"
sedi "s/iTerm2 Solarized [a-zA-Z]*/iTerm2 Solarized ${themeCap}/" "$GHOSTTY_CONFIG"
echo "Super+Shift+, to reload the theme."
